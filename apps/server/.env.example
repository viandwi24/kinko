# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
# RPC URL yang dikembalikan ke frontend (bisa pakai public endpoint, tanpa API key)
PUBLIC_RPC_URL=https://api.devnet.solana.com
ANCHOR_PROGRAM_ID=aAm7smaMYpPzx4PN7LdzRyPd1AqVLzRWbHjCc3qJkXL

# Agent identity
SERVER_AGENT_NAME=Kinko
SERVER_AGENT_IMAGE_URL=${SERVER_URL}/.well-known/logo.png
SERVER_AGENT_PRIVATE_KEY=[1,2,3,...]
SERVER_AGENT_ASSET_ADDRESS=

# AI (OpenRouter — https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-...
AI_MODEL=openai/gpt-4o-mini

# Server
PORT=3001
SERVER_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Cost per chat request in lamports (10000000 = 0.01 SOL)
COST_PER_REQUEST_LAMPORTS=10000000

# A2A — Kinko Prices sub-agent (register with: bun run register-prices-agent)
KINKO_PRICES_ASSET_ADDRESS=

# Metaplex agent discovery (Helius DAS API — optional, improves discovery)
HELIUS_API_KEY=your-helius-api-key
