{
  "name": "kinko",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "contract"
  ],
  "scripts": {
    "register-agent": "bun run scripts/register-agent.ts",
    "register-prices-agent": "bun run scripts/register-prices-agent.ts",
    "update-agent-name": "bun run scripts/update-agent-name.ts",
    "setup": "bun run apps/setup-tui/src/index.tsx",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:server": "bun run --cwd apps/server dev",
    "build:web": "bun run --cwd apps/web build",
    "build:contract": "cd contract && anchor build",
    "deploy:contract": "cd contract && anchor deploy --provider.cluster devnet --provider.wallet ../data/agent-keypair.json",
    "program-init-config": "bun run scripts/program-init-config.ts",
    "program-migrate-account": "bun run scripts/program-migrate-account.ts",
    "program-sim-yield": "bun run scripts/program-sim-yield.ts",
    "dev": "concurrently -p \"[{name}]\" -n \"WEB,SERVER\" -c \"blue,green\" \"bun run dev:web\" \"bun run dev:server\""
  },
  "devDependencies": {
    "@types/bun": "latest",
    "concurrently": "^9.2.1",
    "typescript": "^5"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@metaplex-foundation/mpl-core": "^1.9.0",
    "@metaplex-foundation/umi": "^1.5.1",
    "@solana/web3.js": "1"
  }
}
