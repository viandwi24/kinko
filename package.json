{
  "name": "kinko",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "contract"
  ],
  "scripts": {
    "dev:web": "bun run --cwd apps/web dev",
    "dev:server": "bun run --cwd apps/server dev",
    "dev:agent-b": "bun run --cwd apps/agent-b dev",
    "build:web": "bun run --cwd apps/web build",
    "build:contract": "cd contract && anchor build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
